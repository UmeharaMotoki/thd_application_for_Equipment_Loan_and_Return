# PostgreSQL（docker-compose の db サービス向け）
# DB 未接続で申請だけ試す場合は、この行をコメントアウトするか、下記 THD_SUBMISSION_MODE=json を設定。
DATABASE_URL="postgresql://thd:thd_dev_password@localhost:5432/thd?schema=public"

# 申請の保存先: json = 下流用 JSON を `../JSON/議事送信` に必ず保存。DATABASE_URL があるときはローカル DB（一覧・一時保管）にも二重保存。
# THD_SUBMISSION_MODE=json
# 保存先の上書き（省略時はリポジトリの docker/JSON/議事送信）
# THD_JSON_SUBMISSION_DIR="C:\\Users\\you\\Documents\\claude_code\\docker\\JSON\\議事送信"

# 機器貸与 Excel 帳票（PoC）。未設定時は docker/要件定義/テスト/
# THD_LENDING_EXPORT_DIR="C:\\Users\\you\\Documents\\claude_code\\docker\\要件定義\\テスト"

# 将来の AWS 移設を見据えた切り替え用
# local | s3
FILE_STORAGE_DRIVER="local"

# S3 利用時のみ設定
S3_BUCKET_NAME=""
AWS_REGION="ap-northeast-1"

# --- マスタ取込（人事 xlsx / 納品先 xlsx）---
# 手動アップロード・POST /api/admin/masters/sync で必須（十分に長いランダム文字列を設定）
MASTER_IMPORT_SECRET=""

# S3 からの自動取込用（バケット内オブジェクトキー。IAM は s3:GetObject など）
MASTER_S3_BUCKET=""
MASTER_S3_HR_KEY=""
MASTER_S3_DELIVERY_KEY=""
# 認証: 環境変数 AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY または ECS/IAM ロール
